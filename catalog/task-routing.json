{
  "schema_version": 1,
  "updated_at": "2026-07-21",
  "last_verified_at": "2026-07-21",
  "notes": "Domain→model matrix verified against catalog/models.json on last_verified_at. Model IDs must exist in models.json providers.",
  "philosophy": [
    "Main Claude thread stays on one provider for prompt-cache continuity (miss ~10x).",
    "Route isolated subtasks by capability×cost; escalate only after failed verification (max 2 retries/tier).",
    "Writes stay single-threaded; helpers inject intelligence (review/research), not parallel writers (Cognition 2026).",
    "Multi-agent only for XL parallel-read/research/review; coding default is single strong thread (Anthropic 15x tokens)."
  ],
  "domains": {
    "plan": {
      "label": "기획 / PRD / 범위",
      "keywords": ["plan", "prd", "roadmap", "scope", "기획", "요구사항", "user story", "jtbd", "우선순위"],
      "grade_default": "L",
      "primary": {"provider": "claude", "model": "claude-opus-4-8", "why": "judgment-heavy product decisions"},
      "alternates": [
        {"provider": "openai", "model": "gpt-5.6-sol", "why": "strong professional reasoning"},
        {"provider": "grok", "model": "grok-4.5", "why": "fast top-tier + search tools for market context"}
      ],
      "avoid": ["local", "haiku", "luna"],
      "verify": "human_gate",
      "token_tips": ["Keep plan artifacts on disk; don't re-feed full chat history each turn"]
    },
    "architecture": {
      "label": "아키텍처 / 시스템 설계",
