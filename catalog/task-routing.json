      "grade_default": "L",
      "primary": {"provider": "claude", "model": "claude-opus-4-8", "why": "best agentic design judgment for coding systems"},
      "alternates": [
        {"provider": "openai", "model": "gpt-5.6-sol"},
        {"provider": "gemini", "model": "gemini-3.1-pro-preview", "why": "complex multimodal/system reasoning"}
