      "avoid": ["local", "cheap"],
      "verify": "clean_context_review"
    },
    "design": {
      "label": "UI/UX 디자인 · 목업",
      "keywords": ["design", "ui", "ux", "mockup", "wireframe", "디자인", "figma", "layout", "visual"],
      "grade_default": "M",
      "primary": {"provider": "gemini", "model": "gemini-3.5-flash", "why": "strong multimodal + design workflows"},
      "alternates": [
        {"provider": "gemini", "model": "gemini-3-pro-image", "why": "image/mock generation"},
        {"provider": "claude", "model": "claude-sonnet-5", "why": "design system + component code"}
