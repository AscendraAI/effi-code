  "cascade": {
    "order_cloud": ["local", "cheap", "mid", "top", "ultra"],
    "max_attempts_per_tier": 2,
    "escalate_on": ["verify_fail", "ambiguous_spec", "security_flag", "multi_file_regression"]
  },
  "cost_guards": {
    "default_start_tier": "mid",
    "prefer_local_for": ["bulk", "docs_mechanical"],
    "main_thread_provider_lock": "claude",
    "subtask_may_cross_provider": true
  }
