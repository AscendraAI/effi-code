# 실제 작업 산출물은 공개하지 않음 (템플릿만 공개)
tasks/
# project marker when developing the toolkit itself
.effi-root

# 비밀·설정
.env
*.local.json
config.local.*
# never commit real account keys (use accounts.example.json only)
config/accounts.json
**/accounts.local.json

# OS / 에디터
.DS_Store
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# 로컬 모델
*.gguf

# effi-edit sidecar drafts (review before --apply)
*.effi-new

# bkit 플러그인 상태 (공개 안 함)
.bkit/
.claude/
