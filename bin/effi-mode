#!/usr/bin/env bash
# effi-mode — Apex / Cruise / Sip orchestration mode
#
#   effi mode              # show current + menu
#   effi mode list
#   effi mode set apex     # or 1 / max / 풀파워
#   effi mode set cruise   # or 2
#   effi mode set sip      # or 3 / thrift / 알뜰
#   effi mode ask          # interactive picker (first-run style)
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export PYTHONPATH="$ROOT/lib${PYTHONPATH:+:$PYTHONPATH}"

CMD="${1:-show}"
[ "$#" -gt 0 ] && shift || true

case "$CMD" in
  show|status|"")
    python3 - <<'PY'
from effi_core import get_mode, mode_is_set, list_modes, print_mode_menu
m = get_mode()
src = "set" if mode_is_set() else "default (not pinned — run: effi mode ask)"
print(f"{m.get('emoji','')} {m['name']}  [{m['id']}]  · {src}")
print(f"  {m.get('tagline')}")
print(f"  {m.get('banner')}")
print()
print_mode_menu()
print(f"active → {m['id']}")
PY
    ;;
  list)
    python3 - <<'PY'
from effi_core import list_modes
for m in list_modes():
    mark = "*" if m.get("active") else " "
    print(f"{mark} [{m['number']}] {m.get('emoji','')} {m['name']:7}  {m['id']:7}  {m.get('tagline')}")
PY
    ;;
  set)
    TOKEN="${1:-}"
    [ -z "$TOKEN" ] && { echo "usage: effi mode set <apex|cruise|sip|1|2|3>" >&2; exit 1; }
    TOKEN="$TOKEN" python3 - <<'PY'
import os, sys
from effi_core import set_mode
try:
    m = set_mode(os.environ["TOKEN"])
except KeyError as e:
    print(e, file=sys.stderr); sys.exit(1)
print(f"✓ mode → {m.get('emoji','')} {m['name']} ({m['id']})")
print(f"  {m.get('banner')}")
print("  switch anytime: effi mode set apex|cruise|sip")
PY
    ;;
  ask|pick|select)
    python3 - <<'PY'
from effi_core import ensure_mode, mode_is_set
# force ask even if set? only if --force not passed; ask always re-prompts
import sys
# clear sticky for re-ask: user explicitly ran ask
from effi_core import load_state, save_state, set_mode, print_mode_menu, resolve_mode_id
print_mode_menu()
try:
    import sys as _s
    _s.stderr.write("mode> ")
    _s.stderr.flush()
    line = _s.stdin.readline()
except EOFError:
    line = ""
choice = (line or "").strip() or "cruise"
try:
    m = set_mode(choice)
except KeyError as e:
    print(e); m = set_mode("cruise")
print(f"✓ mode → {m.get('emoji','')} {m['name']} ({m['id']})")
print(f"  {m.get('banner')}")
PY
    ;;
  -h|--help|help)
    sed -n '2,12p' "$0" | tr -d '#'
    ;;
  *)
    # bare token: treat as set
    if [[ "$CMD" =~ ^(apex|cruise|sip|1|2|3|max|min|thrift|balance)$ ]]; then
      exec "$0" set "$CMD"
    fi
    echo "usage: effi mode [show|list|set <name>|ask]" >&2
    exit 1
    ;;
esac
