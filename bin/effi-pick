#!/usr/bin/env bash
# effi-pick — task-aware + RAM-aware local model recommendation
#   effi-pick                     # best general local for current RAM
#   effi-pick --task "번역 40개"  # role-biased pick
#   effi-pick --json
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export PYTHONPATH="$ROOT/lib${PYTHONPATH:+:$PYTHONPATH}"

TASK=""; JSON=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --task|-t) TASK="$2"; shift 2 ;;
    --json|-j) JSON=1; shift ;;
    -h|--help) echo "usage: effi-pick [--task text] [--json]"; exit 0 ;;
    *) TASK="${TASK:+$TASK }$1"; shift ;;
  esac
done

TASK="$TASK" JSON="$JSON" python3 - <<'PY'
import os, sys
from effi_core import pick_local, recommend, print_json

task = os.environ.get("TASK") or ""
roles = None
if task:
    rec = recommend(task)
    # map domain to local roles
    d = rec["domain"]
    role_map = {
        "bulk": ["boilerplate", "translate", "docstring", "format"],
        "docs": ["docstring", "translate"],
        "test": ["scaffold", "boilerplate"],
        "implement": ["implement_narrow", "scaffold"],
        "refactor": ["implement_narrow", "boilerplate"],
        "debug": ["implement_narrow"],
    }
    roles = role_map.get(d, ["implement_narrow"])

pick = pick_local(roles)
# stderr rationale for scripts that only want model on stdout
print(
    f"[effi-pick] total={pick['total_gb']}GB avail={pick['avail_gb']}GB "
    f"budget={pick['budget_gb']}GB → {pick['model']}  ({pick['reason']})",
    file=sys.stderr,
)
if not pick.get("fit"):
    print("[effi-pick] ⚠️ RAM tight — close apps for a stronger model", file=sys.stderr)

if os.environ.get("JSON") == "1":
    if task:
        pick["task_domain"] = rec["domain"]
        pick["roles"] = roles
    print_json(pick)
else:
    print(pick["model"])
PY
