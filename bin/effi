#!/usr/bin/env bash
# effi-code 런처/토글 — 평소 구독 Claude, 쿼터 소진 시 로컬로 전환.
#   ( effi-code 툴킷의 런처. 명령 이름 effi )
#
#   effi            평소 = CLOUD (구독 Claude+Codex+Gemini 오케스트레이션)
#   effi local      LOCAL 모드로 Claude Code 실행 (무료, 쿼터 백스톱)
#   effi cloud      CLOUD 모드로 실행 (기본과 동일)
#   effi status     현재 모드/로컬 상태 확인
#
# 구독은 프록시로 못 돌린다(Anthropic ToS, 2026-02). 그래서 "라우터"가 아니라
# 이 토글이 정답 — 한도 메시지를 보면 `effi local`로 이어서 작업.
set -euo pipefail

LOCAL_MODEL="${EFFI_LOCAL_MODEL:-}"   # 비었으면 effi-pick가 현재 가용 메모리에 맞춰 자동 선택
OLLAMA_URL="http://localhost:11434"

ensure_ollama() {
  if ! curl -sf "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
    echo "  · Ollama 데몬 기동…"; (ollama serve >/tmp/ollama-serve.log 2>&1 &) ; sleep 2
  fi
}

MODE="${1:-cloud}"; shift || true
case "$MODE" in
  local)
    ensure_ollama
    if [ -z "$LOCAL_MODEL" ]; then LOCAL_MODEL="$(effi-pick 2>/dev/null || echo qwen2.5-coder:3b)"; fi
    ollama list 2>/dev/null | grep -q "$LOCAL_MODEL" || { echo "  · $LOCAL_MODEL 다운로드…"; ollama pull "$LOCAL_MODEL"; }
    export ANTHROPIC_BASE_URL="$OLLAMA_URL"
    export ANTHROPIC_API_KEY="ollama"
    export ANTHROPIC_MODEL="$LOCAL_MODEL"
    export ANTHROPIC_SMALL_FAST_MODEL="$LOCAL_MODEL"
    export OLLAMA_KEEP_ALIVE="30m"           # 모델을 메모리에 유지 → 매 호출 로드 지연 제거
    echo "▶ LOCAL 모드 · $LOCAL_MODEL (무료·로컬). 스코프 좁은 작업 위주로. 어려운 건 유료 복구 후."
    # 작은 로컬 모델은 MCP 도구 수백 개에 파묻히면 오작동한다.
    # --strict-mcp-config 로 MCP 전부 끄고 내장 코딩 도구만 남긴다(안정성↑).
    exec claude --strict-mcp-config "$@"
    ;;
  cloud)
    unset ANTHROPIC_BASE_URL ANTHROPIC_API_KEY ANTHROPIC_MODEL ANTHROPIC_SMALL_FAST_MODEL 2>/dev/null || true
    echo "▶ CLOUD 모드 · 구독 Claude"
    exec claude "$@"
    ;;
  status)
    if [ -n "$LOCAL_MODEL" ]; then echo "로컬 모델(고정): $LOCAL_MODEL"; else echo "로컬 모델(자동): $(effi-pick 2>/dev/null || echo '?')"; fi
    if curl -sf "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
      echo "Ollama: ✅ 실행 중"; ollama list 2>/dev/null | grep -iE 'coder|devstral' || true
    else echo "Ollama: ❌ 꺼짐 (effi local 시 자동 기동)"; fi
    ;;
  *)
    echo "사용법: effi [cloud|local|status]"; exit 1 ;;
esac
