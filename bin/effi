#!/usr/bin/env bash
# effi-code v4 launcher — multi-provider routing + account rotation + local pick
#
#   effi                 CLOUD Claude (auto account select under usage threshold)
#   effi local           LOCAL Ollama backend for Claude Code
#   effi cloud           same as default cloud
#   effi status          health: accounts, catalog, local model
#
#   effi route "…"       task → optimal model (claude/codex/gemini/grok/local)
#   effi accounts …      multi-account rotation
#   effi catalog …       biweekly model catalog
#   effi pick / run / edit / new / review / classify
#
# ToS: never proxy subscription OAuth through third-party routers.
set -euo pipefail

BIN="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$BIN/.." && pwd)"
export PATH="$BIN:$PATH"
export PYTHONPATH="$ROOT/lib${PYTHONPATH:+:$PYTHONPATH}"

LOCAL_MODEL="${EFFI_LOCAL_MODEL:-}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"

curl_ollama() {
  curl -sf --connect-timeout 1 --max-time 3 "$@"
}

ensure_ollama() {
  if ! curl_ollama "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
    echo "  · Ollama starting…"
    (ollama serve >/tmp/ollama-serve.log 2>&1 &)
    sleep 2
  fi
}

apply_cloud_account() {
  # Rotate Claude account if configured; ignore if none
  if [ -f "$HOME/.config/effi/accounts.json" ]; then
    if OUT="$("$BIN/effi-accounts" select 2>&1)"; then
      echo "$OUT" | sed 's/^/  · /'
      # shellcheck disable=SC1090
      eval "$("$BIN/effi-accounts" env 2>/dev/null)" || true
    fi
  fi
}

MODE="${1:-cloud}"
if [ "$#" -gt 0 ]; then shift; fi

case "$MODE" in
  local)
    ensure_ollama
    if [ -z "$LOCAL_MODEL" ]; then
      LOCAL_MODEL="$("$BIN/effi-pick" 2>/dev/null || echo qwen2.5-coder:3b)"
    fi
    if ! ollama list 2>/dev/null | grep -q "${LOCAL_MODEL%%:*}"; then
      echo "  · pulling $LOCAL_MODEL …"
      ollama pull "$LOCAL_MODEL" || true
    fi
    export ANTHROPIC_BASE_URL="$OLLAMA_URL"
    export ANTHROPIC_API_KEY="ollama"
    export ANTHROPIC_MODEL="$LOCAL_MODEL"
    export ANTHROPIC_SMALL_FAST_MODEL="$LOCAL_MODEL"
    export OLLAMA_KEEP_ALIVE="30m"
    echo "▶ LOCAL · $LOCAL_MODEL · narrow tasks only · MCP off"
    exec claude --strict-mcp-config "$@"
    ;;
  cloud)
    # clear local overrides
    unset ANTHROPIC_BASE_URL ANTHROPIC_MODEL ANTHROPIC_SMALL_FAST_MODEL 2>/dev/null || true
    # Mode: ask once per project if no project pin (TTY), then banner
    python3 - <<'PY'
from effi_core import ensure_mode, mode_source
m = ensure_mode(interactive=True)
print(f"▶ {m.get('emoji','')} {m['name'].upper()} · {m.get('banner')}")
src = m.get("source") or mode_source()
if src == "project":
    print("  project pin · switch: effi mode set apex|cruise|sip")
elif src == "env":
    print("  EFFI_MODE · unset to pick per project")
elif src == "global":
    print("  global default · pin this project: effi mode set …")
else:
    print("  (default Cruise — pin with: effi mode set cruise)")
PY
    apply_cloud_account
    echo "▶ CLOUD · rules: ORCHESTRATION.md + catalog routing"
    if command -v claude >/dev/null 2>&1; then
      exec claude "$@"
    else
      echo "claude CLI not found" >&2; exit 1
    fi
    ;;
  status)
    echo "=== effi-code $(cat "$ROOT/VERSION" 2>/dev/null || echo '?') ==="
    echo "project: $(python3 -c "import sys; sys.path.insert(0,'$ROOT/lib'); from effi_core import project_root; print(project_root())" 2>/dev/null || pwd)"
    python3 -c "import sys; sys.path.insert(0,'$ROOT/lib'); from effi_core import get_mode, mode_is_set; m=get_mode(); print(f\"mode: {m.get('emoji','')} {m['name']} ({m['id']})\" + ('' if mode_is_set() else ' [default]'))" 2>/dev/null || true
    "$BIN/effi-catalog" status 2>/dev/null || true
    echo
    if [ -f "$HOME/.config/effi/accounts.json" ]; then
      "$BIN/effi-accounts" status
    else
      echo "accounts: (not configured) → effi accounts init"
    fi
    echo
    if [ -n "$LOCAL_MODEL" ]; then
      echo "local model (pinned): $LOCAL_MODEL"
    else
      echo "local model (auto):"
      "$BIN/effi-pick" 2>&1 || true
    fi
    if curl_ollama "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
      echo "Ollama: ✅"
      ollama list 2>/dev/null | head -15 || true
    else
      echo "Ollama: ❌ off"
    fi
    echo "orchestration: multi-provider · single-writer · clean-context verify · 3 modes"
    ;;
  route|recommend) exec "$BIN/effi-route" "$@" ;;
  accounts|account) exec "$BIN/effi-accounts" "$@" ;;
  catalog) exec "$BIN/effi-catalog" "$@" ;;
  pick) exec "$BIN/effi-pick" "$@" ;;
  run) exec "$BIN/effi-run" "$@" ;;
  edit) exec "$BIN/effi-edit" "$@" ;;
  new) exec "$BIN/effi-new" "$@" ;;
  classify) exec "$BIN/effi-classify" "$@" ;;
  review) exec "$BIN/effi-review" "$@" ;;
  init) exec "$BIN/effi-init" "$@" ;;
  doctor) exec "$BIN/effi-doctor" "$@" ;;
  use) exec "$BIN/effi-use" "$@" ;;
  log) exec "$BIN/effi-log" "$@" ;;
  mode) exec "$BIN/effi-mode" "$@" ;;
  help|-h|--help)
    cat <<'EOF'
effi — cost-aware multi-provider coding orchestrator (effi-code)

Modes (pick anytime)
  🚀 Apex    [1]  max performance — ignore quota, no local primary
  🛣 Cruise  [2]  performance + cost (default effi balance)
  ☕ Sip     [3]  minimum cost — local/cheap first
  effi mode              show / menu
  effi mode set apex     pin mode (aliases: 1, max, 풀파워…)
  effi mode ask          interactive picker

Sessions
  effi [cloud]             Claude cloud (asks mode if unset)
  effi local               Ollama local backend
  effi status · doctor · init

Routing
  effi route|use "task…"   model pick (respects active mode)
  effi pick · run · edit · …

Accounts / catalog / tasks
  effi accounts … · catalog … · new … · log … · review …

Rules: ORCHESTRATION.md  Modes: catalog/modes.json
EOF
    ;;
  *)
    echo "usage: effi [cloud|local|mode|status|doctor|init|route|use|log|accounts|catalog|pick|run|edit|new|review|help]" >&2
    exit 1
    ;;
esac
