#!/usr/bin/env bash
# effi-run — local model mechanical worker (task-aware model pick)
#
#   effi-run "docstrings for: …"
#   effi-run -m devstral "…"
#   effi-run -t "번역" "40 UI strings…"   # bias pick via task hint
#   effi-run -s "JSON only" --json "…"
#   effi-run -f path.py "add type hints, full file only"
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export PYTHONPATH="$ROOT/lib${PYTHONPATH:+:$PYTHONPATH}"
export PATH="$ROOT/bin:$PATH"

MODEL="${EFFI_LOCAL_MODEL:-}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"
SYSTEM=""
FILE_CTX=""
JSON_MODE=0
TASK_HINT=""

usage() {
  echo "사용법: effi-run [-m model] [-t task-hint] [-s system] [-f file] [--json] \"work\"" >&2
  exit 1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -m) MODEL="$2"; shift 2 ;;
    -t) TASK_HINT="$2"; shift 2 ;;
    -s) SYSTEM="$2"; shift 2 ;;
    -f) FILE_CTX="$2"; shift 2 ;;
    --json) JSON_MODE=1; shift ;;
    -h|--help) usage ;;
    --) shift; break ;;
    -*) echo "unknown: $1" >&2; usage ;;
    *) break ;;
  esac
done

if [ -z "$MODEL" ]; then
  if [ -n "$TASK_HINT" ]; then
    MODEL="$(effi-pick --task "$TASK_HINT" 2>/dev/null || true)"
  else
    MODEL="$(effi-pick 2>/dev/null || true)"
  fi
  MODEL="${MODEL:-qwen2.5-coder:3b}"
fi

if [ "$#" -gt 0 ]; then PROMPT="$*"; else PROMPT="$(cat)"; fi
[ -z "${PROMPT:-}" ] && usage

if [ -n "$FILE_CTX" ]; then
  [ -f "$FILE_CTX" ] || { echo "no file: $FILE_CTX" >&2; exit 1; }
  PROMPT="## File: ${FILE_CTX}
\`\`\`
$(cat "$FILE_CTX")
\`\`\`

## Task
${PROMPT}"
fi

if [ "$JSON_MODE" -eq 1 ]; then
  SYSTEM="${SYSTEM:+$SYSTEM$'\n'}Output valid JSON only. No markdown fences, no commentary."
fi
if [ -z "$SYSTEM" ]; then
  SYSTEM="You are a careful coding assistant for mechanical bulk tasks. Follow instructions exactly. Prefer complete ready-to-use output over explanations."
fi

curl -sf --connect-timeout 1 --max-time 3 "$OLLAMA_URL/api/tags" >/dev/null 2>&1 || {
  echo "Ollama off — run: ollama serve" >&2; exit 1
}

echo "[effi-run] model=$MODEL" >&2

export SAG_MODEL="$MODEL" SAG_PROMPT="$PROMPT" SAG_SYSTEM="$SYSTEM" SAG_URL="$OLLAMA_URL"
python3 - <<'PY'
import os, json, urllib.request, sys
body = {
    "model": os.environ["SAG_MODEL"],
    "messages": [
        {"role": "system", "content": os.environ["SAG_SYSTEM"]},
        {"role": "user", "content": os.environ["SAG_PROMPT"]},
    ],
    "stream": False,
    "keep_alive": "30m",
    "options": {"temperature": 0.2},
}
req = urllib.request.Request(
    os.environ["SAG_URL"] + "/api/chat",
    data=json.dumps(body).encode(),
    headers={"content-type": "application/json"},
)
try:
    with urllib.request.urlopen(req, timeout=600) as r:
        d = json.load(r)
except Exception as e:
    print("local run failed:", e, file=sys.stderr); sys.exit(1)
msg = d.get("message") or {}
print((msg.get("content") or d.get("response") or "").rstrip())
PY
