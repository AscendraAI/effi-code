#!/usr/bin/env bash
# effi-new — scaffold tasks/<name>/ in the *project* root (cwd/git), not toolkit install.
#
#   effi-new tip-app
#   effi-new tip-app "CLI random tips"
#   EFFI_PROJECT=/path/to/app effi-new foo "goal"
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export PYTHONPATH="$ROOT/lib${PYTHONPATH:+:$PYTHONPATH}"

NAME="${1:-}"
GOAL="${2:-}"
[ -z "$NAME" ] && { echo "usage: effi-new <name> [goal]" >&2; exit 1; }

python3 - "$ROOT" "$NAME" "$GOAL" <<'PY'
import re, sys
from datetime import datetime
from pathlib import Path

toolkit, name, goal = sys.argv[1], sys.argv[2], sys.argv[3]
sys.path.insert(0, str(Path(toolkit) / "lib"))
from effi_core import recommend, project_root, tasks_dir

name = re.sub(r"[^a-z0-9._-]+", "-", name.lower()).strip("-")
proj = project_root()
base = tasks_dir(proj)
out = base / name
if out.exists():
    print(f"already exists: {out}", file=sys.stderr)
    sys.exit(1)

out.mkdir(parents=True)
(out / "workers" / "review").mkdir(parents=True)

route_text = goal or name
# project-local mode adjust by task importance (TTY)
rec = recommend(route_text, adjust_mode=True, interactive=True)
primary = f"{rec['primary_provider']}/{rec['primary_model']}"
grade = rec.get("grade", "M")
domain = rec.get("domain", "implement")
review = rec.get("review", "clean_context")
tier = rec.get("start_tier", "mid")
mode = rec.get("mode", "cruise")
today = datetime.now().strftime("%Y-%m-%d")
now = datetime.now().strftime("%Y-%m-%d %H:%M")

text = (Path(toolkit) / "templates" / "task.md").read_text(encoding="utf-8")
text = text.replace("[작업명]", name).replace("<YYYY-MM-DD>", today)
text = text.replace("grade: M", f"grade: {grade}", 1)
text = text.replace("domain: implement", f"domain: {domain}", 1)
text = text.replace("primary: claude/claude-sonnet-5", f"primary: {primary}", 1)
text = text.replace("start_tier: mid", f"start_tier: {tier}", 1)
text = text.replace("review: clean_context", f"review: {review}", 1)
if goal:
    text = text.replace("<!-- 한 문장. 무엇을 완료로 볼 것인가. -->", goal, 1)

(out / "task.md").write_text(text, encoding="utf-8")
imp = rec.get("importance") or (rec.get("mode_adjust") or {}).get("importance") or {}
imp_line = ""
if imp:
    imp_line = (
        f"[{now}] [MODE] importance={imp.get('band')} suggest={imp.get('suggested_mode')} "
        f"active={mode} ({imp.get('reason')})\n"
    )
(out / "log.md").write_text(
    f"""# log — {name}

<!-- append-only -->

[{now}] [DECISION] task folder created (effi-new) project={proj}
[{now}] [TRIAGE] domain={domain} grade={grade} model={primary} review={review} mode={mode}
{imp_line}""",
    encoding="utf-8",
)
brief = (Path(toolkit) / "templates" / "review.md").read_text(encoding="utf-8")
(out / "workers" / "review" / "brief.md").write_text(brief, encoding="utf-8")

print(f"✓ {out}")
print(f"  project={proj}")
print(f"  domain={domain}  grade={grade}  primary={primary}  mode={mode}")
print("  task.md  log.md  workers/review/brief.md")
PY
